{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    /* MUDANÇA CRÍTICA: Desativa a obrigatoriedade de inicializar propriedades no constructor.
       Isso resolve os erros nas Entities do TypeORM (Aluno, Usuario, etc).
    */
    "strictPropertyInitialization": false, 
    "noImplicitAny": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "noEmit": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "itp_frontend",
    "test",
    "**/*.spec.ts"
  ]
}