{
  "name": "itp-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "itp_frontend"
  ],
  "scripts": {
    "build:backend": "nest build",
    "build:frontend": "npm run build --workspace=itp_frontend",
    "vercel-build": "npm run build:backend && npm run build:frontend",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.19",
    "typescript": "^5.7.3"
  }
}