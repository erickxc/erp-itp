{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "itp_frontend/package.json",
      "use": "@vercel/next",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "src/main.ts"
    },
    {
      "source": "/api/matriculas/:path*",
      "destination": "src/main.ts"
    },
    {
      "source": "/api/materias/:path*",
      "destination": "src/main.ts"
    },
    {
      "source": "/api/users/:path*",
      "destination": "src/main.ts"
    },
    {
      "source": "/((?!api).*)" ,
      "destination": "itp_frontend/$1"
    }
  ]
}