{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "itp_frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "src/main.ts"
    },
    {
      "source": "/users/(.*)",
      "destination": "src/main.ts"
    },
    {
      "source": "/matriculas/(.*)",
      "destination": "src/main.ts"
    },
    {
      "source": "/materias/(.*)",
      "destination": "src/main.ts"
    },
    {
      "source": "/((?!auth|users|matriculas|materias).*)",
      "destination": "itp_frontend/$1"
    }
  ]
}